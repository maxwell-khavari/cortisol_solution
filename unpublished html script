      <div class="report-row"><span class="rk">Total time reclaimed</span><span class="rv" id="rep-total">—</span></div>
    </div>
 
    <div id="heatmap-wrap">
      <div class="section-title">84-day session heatmap</div>
      <div id="heatmap-grid"></div>
    </div>
 
    <div id="stress-history-wrap">
      <div class="section-title">Stress levels — recent sessions</div>
      <div id="stress-chart"></div>
    </div>
 
    <div id="journal-wrap">
      <div class="journal-prompt" id="journal-prompt">"What do you notice in your body right now?"</div>
      <textarea id="journal-input" placeholder="Write freely — this is just for you..."></textarea>
    </div>
 
    <div class="done-actions">
      <button class="again-btn" id="again-btn">GO AGAIN</button>
      <button class="again-btn" id="save-journal-btn">SAVE NOTE</button>
    </div>
  </div>
</div>
 
<script>
/* ── Storage ── */
const SK = 'stillness_v2';
function load() { try { return JSON.parse(localStorage.getItem(SK)) || def(); } catch { return def(); } }
function def() { return {sessions:0,totalMin:0,streak:0,lastDate:null,sessionDates:{},stressLog:[],journals:[]}; }
function save(d) { try { localStorage.setItem(SK, JSON.stringify(d)); } catch {} }
 
/* ── Theme ── */
let manualTheme = null;
function applyTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  document.getElementById('theme-toggle').textContent = t==='night' ? '☀ DAY' : '☽ NIGHT';
}
function autoTheme() { if (!manualTheme) { const h = new Date().getHours(); applyTheme((h>=20||h<7)?'night':'day'); } }
autoTheme(); setInterval(autoTheme, 60000);
document.getElementById('theme-toggle').addEventListener('click', () => {
  const cur = document.documentElement.getAttribute('data-theme');
  manualTheme = cur==='night' ? 'day' : 'night';
  applyTheme(manualTheme);
});
 
/* ── Cursor ── */
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => { cursor.style.left=e.clientX+'px'; cursor.style.top=e.clientY+'px'; });
function hookCursor() {
  document.querySelectorAll('button,input,textarea').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('big'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
  });
}
 
/* ── Background canvas (aurora waves) ── */
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let bgT = 0, bgRunning = false;
function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
window.addEventListener('resize', resizeCanvas); resizeCanvas();
 
function drawBg() {
  if (!bgRunning) return;
  requestAnimationFrame(drawBg);
  bgT += 0.0025;
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const night = document.documentElement.getAttribute('data-theme')==='night';
  const waves = [
    {amp:55, freq:.8, sp:1.0, y:.42, col: night?'rgba(80,55,35,.08)':'rgba(196,168,130,.09)'},
    {amp:70, freq:.5, sp:.65, y:.57, col: night?'rgba(32,65,48,.07)':'rgba(106,140,122,.08)'},
    {amp:45, freq:1.1,sp:1.25,y:.67, col: night?'rgba(55,35,75,.06)':'rgba(170,140,105,.06)'},
  ];
  waves.forEach(w => {
    ctx.beginPath();
    ctx.moveTo(0, canvas.height);
    for (let x=0; x<=canvas.width; x+=5) {
      const y = canvas.height*w.y + Math.sin(x*w.freq*.01+bgT*w.sp)*w.amp
                                   + Math.sin(x*w.freq*.007+bgT*w.sp*1.3)*w.amp*.4;
      ctx.lineTo(x, y);
    }
    ctx.lineTo(canvas.width, canvas.height);
    ctx.fillStyle = w.col; ctx.fill();
  });
}
function startBg() { bgRunning=true; drawBg(); canvas.classList.add('show'); }
function stopBg()  { bgRunning=false; canvas.classList.remove('show'); }
 
/* ── Audio ── */
let audioCtx=null, audioNodes=[], selectedSound='none';
function ac() { if (!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)(); return audioCtx; }
function stopAudio() { audioNodes.forEach(n=>{try{n.stop();}catch{}}); audioNodes=[]; }
 
function startSound(type) {
  stopAudio();
  if (type==='none') return;
  const a=ac(), vol=parseFloat(document.getElementById('vol-slider').value);
  const gain=a.createGain(); gain.gain.value=vol; gain.connect(a.destination);
 
  if (type==='white') {
    const sz=a.sampleRate*4, buf=a.createBuffer(1,sz,a.sampleRate), d=buf.getChannelData(0);
    for (let i=0;i<sz;i++) d[i]=(Math.random()*2-1)*.28;
    const src=a.createBufferSource(); src.buffer=buf; src.loop=true;
    src.connect(gain); src.start(); audioNodes.push(src);
  }
  if (type==='rain') {
    [[180,.35],[750,.28],[3500,.18]].forEach(([f,g],i)=>{
      const sz=a.sampleRate*3, buf=a.createBuffer(1,sz,a.sampleRate), d=buf.getChannelData(0);
      for (let j=0;j<sz;j++) d[j]=Math.random()*2-1;
      const src=a.createBufferSource(); src.buffer=buf; src.loop=true;
      const flt=a.createBiquadFilter(); flt.type='bandpass'; flt.frequency.value=f; flt.Q.value=.6;
      const g2=a.createGain(); g2.gain.value=g;
      src.connect(flt); flt.connect(g2); g2.connect(gain);
      src.start(0,Math.random()*3); audioNodes.push(src);
    });
  }
  if (type==='binaural') {
    const merger=a.createChannelMerger(2); merger.connect(gain);
    [200,210].forEach((freq,ch)=>{
      const osc=a.createOscillator(); osc.type='sine'; osc.frequency.value=freq;
      const g2=a.createGain(); g2.gain.value=.10;
      osc.connect(g2); g2.connect(merger,0,ch); osc.start(); audioNodes.push(osc);
    });
  }
}
 
function playBell() {
  const a=ac(), osc=a.createOscillator(), gain=a.createGain();
  osc.type='sine'; osc.frequency.setValueAtTime(528,a.currentTime);
  osc.frequency.exponentialRampToValueAtTime(220,a.currentTime+2);
  gain.gain.setValueAtTime(.3,a.currentTime);
  gain.gain.exponentialRampToValueAtTime(.001,a.currentTime+2.5);
  osc.connect(gain); gain.connect(a.destination); osc.start(); osc.stop(a.currentTime+2.5);
}
 
document.getElementById('vol-slider').addEventListener('input', ()=>{ if (audioNodes.length) startSound(selectedSound); });
document.querySelectorAll('.snd-btn').forEach(btn => btn.addEventListener('click', ()=>{
  document.querySelectorAll('.snd-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); selectedSound=btn.dataset.sound;
}));
 
/* ── State ── */
let duration=120, remaining=120, interval=null, paused=false;
let breathTimer=null, quoteTimer=null, distractTimer=null;
let phaseIdx=0, breathCount=0, preStress=null, milestonesHit=new Set();
 
/* ── Stress check-in ── */
document.querySelectorAll('.stress-btn').forEach(btn => btn.addEventListener('click', ()=>{
  document.querySelectorAll('.stress-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel'); preStress=parseInt(btn.dataset.v);
  setTimeout(()=>{ document.getElementById('stress-screen').classList.remove('visible'); showIntro(); }, 600);
}));
 
/* ── Intro ── */
function showIntro() {
  const el=document.getElementById('intro');
  el.style.transition='none'; el.classList.remove('hidden'); el.style.opacity=1;
  requestAnimationFrame(()=>{ el.style.transition='opacity 1.2s ease'; });
  updateStatsUI();
}
function updateStatsUI() {
  const s=load();
  document.getElementById('streak-num').textContent=s.streak;
  document.getElementById('sessions-num').textContent=s.sessions;
  document.getElementById('total-min').textContent=Math.round(s.totalMin);
}
 
document.querySelectorAll('.dur-btn').forEach(btn => btn.addEventListener('click', ()=>{
  document.querySelectorAll('.dur-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active'); duration=parseInt(btn.dataset.seconds);
}));
 
document.getElementById('start-btn').addEventListener('click', ()=>{
  document.getElementById('intro').classList.add('hidden');
  setTimeout(startSession, 1200);
});
 
/* ── Session ── */
const phases=[{name:'INHALE',dur:4000,dot:'dot-inhale'},{name:'HOLD',dur:2000,dot:'dot-hold'},{name:'EXHALE',dur:6000,dot:'dot-exhale'}];
const breathGuide=document.getElementById('breath-guide');
 
function startSession() {
  remaining=duration; paused=false; phaseIdx=0; breathCount=0; milestonesHit.clear();
  document.getElementById('session').classList.add('visible');
  updateStatsUI(); updateTimer();
  interval=setInterval(tick,1000);
  runBreath(); startBg(); startSound(selectedSound);
  setTimeout(cycleQuote, 10000);
}
 
function runBreath() {
  const p=phases[phaseIdx];
  breathGuide.textContent=p.name;
  document.querySelectorAll('.phase-dot').forEach(d=>d.classList.remove('active'));
  document.getElementById(p.dot).classList.add('active');
  if (p.name==='INHALE') breathCount++;
  breathTimer=setTimeout(()=>{ phaseIdx=(phaseIdx+1)%phases.length; if(!paused) runBreath(); }, p.dur);
}
 
function fmt(s) { return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`; }
 
function tick() {
  if (paused) return;
  remaining--; updateTimer(); checkMilestones();
  if (remaining<=0) finish();
}
 
function updateTimer() {
  const el=document.getElementById('timer-display');
  el.textContent=fmt(remaining); el.classList.toggle('warn',remaining<=30&&remaining>0);
  document.getElementById('progress-bar').style.width=((duration-remaining)/duration*100)+'%';
}
 
const msMsgs={25:'¼ there — keep breathing',50:'halfway — you\'re doing it',75:'almost done — stay here'};
function checkMilestones() {
  const pct=Math.round((duration-remaining)/duration*100);
  [25,50,75].forEach(m=>{ if(pct>=m&&!milestonesHit.has(m)){ milestonesHit.add(m); playBell(); flashMs(msMsgs[m]); }});
}
function flashMs(msg) {
  const el=document.getElementById('milestone-flash');
  el.textContent=msg; el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3200);
}
 
const quotes=[
  "The present moment is the only moment available.",
  "Boredom is a doorway to depth.",
  "Your attention is the most valuable thing you own.",
  "Stillness is not emptiness — it is fullness.",
  "Rest is not weakness. It is intelligence.",
  "You are already enough, right here.",
  "The mind that wanders can learn to return.",
  "Silence is the language the body speaks.",
  "Let the noise outside become quieter than your breath.",
  "This is the most productive thing you can do right now.",
];
let qi=0;
function cycleQuote() {
  const el=document.getElementById('ambient-quote');
  el.style.opacity=0;
  setTimeout(()=>{ el.textContent=quotes[qi%quotes.length]; el.style.opacity=1; qi++; }, 2000);
  quoteTimer=setTimeout(cycleQuote,20000);
}
 
document.addEventListener('visibilitychange',()=>{
  if(document.hidden&&interval){
    const w=document.getElementById('distraction-warn'); w.classList.add('show');
    clearTimeout(distractTimer); distractTimer=setTimeout(()=>w.classList.remove('show'),4000);
  }
});
 
document.getElementById('pause-btn').addEventListener('click',()=>{
  paused=!paused;
  document.getElementById('pause-btn').textContent=paused?'RESUME':'PAUSE';
  document.getElementById('pause-overlay').classList.toggle('show',paused);
  if (!paused) runBreath();
});
 
document.getElementById('quit-btn').addEventListener('click',()=>{
  if(confirm('End this session early?')) finish(true);
});
 
/* ── Finish ── */
const journalPrompts=[
  '"What do you notice in your body right now?"',
  '"What did your mind keep reaching for during this session?"',
  '"What\'s one thing you\'re grateful for in this moment?"',
  '"How does stillness feel different from being idle?"',
  '"What will you carry from this silence into your day?"',
];
const doneTitles=['Well done.','Beautiful.','You stayed.','Stillness found you.','There you are.'];
 
function finish(early=false) {
  clearInterval(interval); clearTimeout(breathTimer); clearTimeout(quoteTimer); interval=null;
  const minDone=Math.max(0.5, (duration-(early?remaining:0))/60);
 
  const d=load();
  d.sessions+=1; d.totalMin=Math.round((d.totalMin+minDone)*10)/10;
  const today=new Date().toDateString();
  const yesterday=new Date(Date.now()-86400000).toDateString();
  if(d.lastDate!==today) d.streak=(d.lastDate===yesterday)?d.streak+1:1;
  d.lastDate=today;
  const dkey=new Date().toISOString().split('T')[0];
  d.sessionDates[dkey]=(d.sessionDates[dkey]||0)+1;
  if(preStress!==null) d.stressLog.push({date:dkey,v:preStress,min:minDone});
  save(d);
 
  stopAudio(); stopBg();
  buildReport(d, minDone);
  buildHeatmap(d.sessionDates);
  buildStressChart(d.stressLog);
  document.getElementById('journal-prompt').textContent=journalPrompts[d.sessions%journalPrompts.length];
  document.getElementById('journal-input').value='';
  document.getElementById('done-title').textContent=doneTitles[d.sessions%doneTitles.length];
 
  document.getElementById('session').classList.remove('visible');
  document.getElementById('breath-phase').style.opacity=0;
  document.getElementById('ambient-quote').style.opacity=0;
 
  setTimeout(()=>{
    document.getElementById('done-screen').classList.add('visible');
    setTimeout(()=>{ document.getElementById('rep-attn-bar').style.width=Math.min(100,Math.round(minDone/(duration/60)*75+25))+'%'; },300);
  },1500);
}
 
function buildReport(d,minDone) {
  const cortisolPct=Math.min(28,Math.round(minDone*1.6+2));
  document.getElementById('rep-cortisol').textContent=`↓ ~${cortisolPct}%`;
  const attn=Math.min(100,Math.round(minDone/(duration/60)*75+25));
  document.getElementById('rep-attn').textContent=`${attn}/100`;
  if(preStress!==null){
    const postEst=Math.max(1,preStress-Math.round(minDone*0.9+0.5));
    const delta=preStress-postEst;
    document.getElementById('rep-stress-delta').textContent=delta>0?`${preStress} → ~${postEst} (↓${delta})`:`${preStress} (stable)`;
  } else { document.getElementById('rep-stress-delta').textContent='—'; }
  document.getElementById('rep-breaths').textContent=breathCount;
  document.getElementById('rep-total').textContent=`${d.totalMin} min`;
}
 
function buildHeatmap(sessionDates) {
  const grid=document.getElementById('heatmap-grid'); grid.innerHTML='';
  const today=new Date();
  for(let i=83;i>=0;i--){
    const d2=new Date(today); d2.setDate(today.getDate()-i);
    const key=d2.toISOString().split('T')[0];
    const count=sessionDates[key]||0;
    const cell=document.createElement('div'); cell.className='hm-cell';
    cell.title=`${key}: ${count} session${count!==1?'s':''}`;
    cell.dataset.level=Math.min(3,count); grid.appendChild(cell);
  }
}
 
function buildStressChart(stressLog) {
  const chart=document.getElementById('stress-chart'); chart.innerHTML='';
  const recent=stressLog.slice(-24);
  if(!recent.length){document.getElementById('stress-history-wrap').style.display='none';return;}
  document.getElementById('stress-history-wrap').style.display='';
  recent.forEach(e=>{
    const bar=document.createElement('div'); bar.className='sc-bar';
    const pct=e.v/10; bar.style.height=(pct*44)+'px';
    bar.style.background=`color-mix(in srgb,var(--danger) ${Math.round(pct*100)}%,var(--calm))`;
    bar.style.opacity=.5+pct*.5; bar.title=`${e.date}: stress ${e.v}`;
    chart.appendChild(bar);
  });
}
 
document.getElementById('save-journal-btn').addEventListener('click',()=>{
  const text=document.getElementById('journal-input').value.trim();
  if(!text) return;
  const d=load(); d.journals=d.journals||[];
  d.journals.push({date:new Date().toISOString(),text}); save(d);
  const btn=document.getElementById('save-journal-btn');
  btn.textContent='SAVED ✓'; setTimeout(()=>btn.textContent='SAVE NOTE',2000);
});
 
document.getElementById('again-btn').addEventListener('click',()=>{
  document.getElementById('done-screen').classList.remove('visible');
  preStress=null;
  setTimeout(()=>{
    document.querySelectorAll('.stress-btn').forEach(b=>b.classList.remove('sel'));
    document.getElementById('stress-screen').classList.add('visible');
  },800);
});
 
/* ── Boot ── */
window.addEventListener('load',()=>{
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('intro').style.opacity=0;
  document.getElementById('stress-screen').classList.add('visible');
  document.getElementById('stress-history-wrap').style.display='none';
  hookCursor();
});
</script>
</body>
</html>
 

